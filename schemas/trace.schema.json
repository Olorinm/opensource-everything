{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/opensource-everything/trace.schema.json",
  "title": "OpenSource Everything Trace",
  "description": "A product-observation trace collected from computer use, browser inspection, docs, or manual notes.",
  "type": "object",
  "properties": {
    "session": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "source": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "url": { "type": "string" }
          },
          "additionalProperties": true
        },
        "summary": { "type": "string" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "observations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string" },
          "pageId": { "type": "string" },
          "pageTitle": { "type": "string" },
          "pageUrl": { "type": "string" },
          "pagePurpose": { "type": "string" },
          "windowTitle": { "type": "string" },
          "components": {
            "type": "array",
            "items": { "type": "string" }
          },
          "states": {
            "type": "array",
            "items": { "type": "string" }
          },
          "copy": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "action": { "type": "string" },
          "target": { "type": "string" },
          "focusedElement": { "type": "string" },
          "expectedResult": { "type": "string" },
          "observedResult": { "type": "string" },
          "result": { "type": "string" },
          "screenshotPath": { "type": "string" },
          "screenshotLabel": { "type": "string" },
          "flow": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "goal": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "docs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "kind": { "type": "string" },
          "content": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["session", "observations"],
  "additionalProperties": false
}
